{
  "info": {
    "name": "KK Global Group Backend API",
    "description": "Collection for auth, contact, investor and admin routes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Investor",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Investor User\",\n  \"email\": \"investor@example.com\",\n  \"password\": \"Investor@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login Investor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.environment.set('investorToken', json.data.token);",
                  "}",
                  "if (json?.data?.user?.email) {",
                  "  pm.environment.set('investorEmail', json.data.user.email);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"investor@example.com\",\n  \"password\": \"Investor@123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.token) {",
                  "  pm.environment.set('adminToken', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"Manalk14322@gmail.com\",\n  \"password\": \"Manal1212%%\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "Contact",
      "item": [
        {
          "name": "Create Contact",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Client Lead\",\n  \"email\": \"lead@example.com\",\n  \"message\": \"Need consultation for real estate and IT setup.\",\n  \"serviceType\": \"Real Estate\"\n}"
            },
            "url": "{{baseUrl}}/contact"
          }
        },
        {
          "name": "Get Admin Contacts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/contacts"
          }
        }
      ]
    },
    {
      "name": "Investor",
      "item": [
        {
          "name": "Apply Investor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{investorToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Investor User\",\n  \"email\": \"investor@example.com\",\n  \"phone\": \"03185756022\",\n  \"country\": \"Pakistan\",\n  \"investmentAmount\": 50000\n}"
            },
            "url": "{{baseUrl}}/investor/apply"
          }
        },
        {
          "name": "My Applications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{investorToken}}" }],
            "url": "{{baseUrl}}/investor/my-applications"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/dashboard"
          }
        },
        {
          "name": "Get Investors",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/investors"
          }
        },
        {
          "name": "Approve Investor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/investor/{{investorId}}/approve"
          }
        },
        {
          "name": "Reject Investor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/investor/{{investorId}}/reject"
          }
        }
      ]
    }
  ]
}
